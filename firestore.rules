
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the requesting user is an admin.
    // An admin is defined by the existence of a document in the 'roles_admin'
    // collection where the document ID is the user's UID.
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Helper function to check if any admins have been configured yet.
    function noAdminsConfigured() {
      return get(/databases/$(database)/documents/roles_admin).size() == 0;
    }

    // Secure all collections.
    // Allow access if the user is an admin.
    // OR, if no admins have been configured yet, allow any authenticated user access.
    // This allows the first user(s) to use the app and configure the first admin.
    // Once the first admin document is created in 'roles_admin', this rule becomes strict.
    match /{document=**} {
      allow read, write: if request.auth != null && (isAdmin() || noAdminsConfigured());
    }
  }
}


rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /company/{companyId} {
      allow read, write: if request.auth != null;
    }

    match /clients/{clientId} {
      allow read, write: if request.auth != null;
    }

    match /invoices/{invoiceId} {
      allow read, write: if request.auth != null;
    }

    match /invoiceItems/{invoiceItemId} {
      allow read, write: if request.auth != null;
    }
  }
}

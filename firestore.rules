
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      // Using get() instead of exists() as a more robust way to check for the document.
      return request.auth != null && 
        get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) != null;
    }

    match /roles_admin/{userId} {
      // Diagnostic Rule: Allow any authenticated user to read to isolate client-side issues.
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /company/{companyId} {
      allow read, write: if isAdmin();
    }
    
    match /clients/{clientId} {
      allow read, write, delete: if isAdmin();
    }
    match /clients {
      allow list: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read, write, delete: if isAdmin();
    }
    match /invoices {
      allow list: if isAdmin();
    }
  }
}

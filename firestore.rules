
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the requesting user is an admin.
    // An admin is defined by the existence of a document in the 'roles_admin'
    // collection where the document ID is the user's UID.
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // This rule is necessary for the isAdmin() function to work.
    // It allows any authenticated user to check for the existence of their own admin role document.
    match /roles_admin/{uid} {
      allow read: if request.auth != null;
      allow write: if false; // Nobody can write to roles from the client
    }

    // Secure the main data collections.
    // Only admins can read or write documents.
    match /company/{companyId} {
      allow read, write: if isAdmin();
    }
    match /clients/{clientId} {
      allow read, write: if isAdmin();
    }
    match /invoices/{invoiceId} {
      allow read, write: if isAdmin();
    }
  }
}
